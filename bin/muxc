#!/usr/bin/env bash
set -euo pipefail

# muxc — tmux-like session manager for Claude Code

# Resolve lib directory relative to this script
MUXC_LIB="$(dirname "$(readlink -f "$0")")/../lib"

source "$MUXC_LIB/muxc-common.sh"

ensure_muxc_home

cmd="${1:-ls}"
shift 2>/dev/null || true

case "$cmd" in
    new|n)
        source "$MUXC_LIB/muxc-new.sh"
        cmd_new "$@"
        ;;
    attach|a)
        source "$MUXC_LIB/muxc-attach.sh"
        cmd_attach "$@"
        ;;
    detach|d)
        source "$MUXC_LIB/muxc-detach.sh"
        cmd_detach "$@"
        ;;
    ls|list|l)
        source "$MUXC_LIB/muxc-ls.sh"
        cmd_ls "$@"
        ;;
    info|i)
        source "$MUXC_LIB/muxc-info.sh"
        cmd_info "$@"
        ;;
    tag|t)
        source "$MUXC_LIB/muxc-tag.sh"
        cmd_tag "$@"
        ;;
    note)
        source "$MUXC_LIB/muxc-note.sh"
        cmd_note "$@"
        ;;
    rename|mv)
        source "$MUXC_LIB/muxc-rename.sh"
        cmd_rename "$@"
        ;;
    archive)
        source "$MUXC_LIB/muxc-archive.sh"
        cmd_archive "$@"
        ;;
    kill|k)
        source "$MUXC_LIB/muxc-kill.sh"
        cmd_kill "$@"
        ;;
    rm)
        source "$MUXC_LIB/muxc-rm.sh"
        cmd_rm "$@"
        ;;
    import)
        source "$MUXC_LIB/muxc-import.sh"
        cmd_import "$@"
        ;;
    help|h|-h|--help)
        source "$MUXC_LIB/muxc-help.sh"
        cmd_help "$@"
        ;;
    version|-v|--version)
        echo "🔧 muxc $MUXC_VERSION"
        ;;
    *)
        die "Unknown command: $cmd. Run 'muxc help' for usage."
        ;;
esac
